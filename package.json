{
  "name": "mysugya",
  "private": true,
  "version": "13.00",
  "description": "My Sugya - universal Talmud study companion",
  "scripts": {
    "test": "python3 tests/smoke/render_check.py",
    "serve": "npm run build && python3 -m http.server 4173 --bind 127.0.0.1 --directory dist",
    "validate:yoma": "cd modules/yoma && python3 scripts/validate_sefaria.py",
    "audit:yoma": "cd modules/yoma && python3 scripts/completeness_audit.py",
    "audit:order:yoma": "cd modules/yoma && python3 scripts/order_audit.py",
    "validate:en:yoma": "cd modules/yoma && python3 scripts/validate_en.py",
    "validate:daftext:yoma": "cd modules/yoma && python3 scripts/validate_daftext.py",
    "validate:rashi:yoma": "cd modules/yoma && python3 scripts/validate_rashi.py",
    "fetch:literal:yoma": "cd modules/yoma && python3 scripts/fetch_literal_en.py --all --skip-existing",
    "build:literal:yoma": "cd modules/yoma && python3 scripts/build_literal_layer.py --apply",
    "validate:literal:yoma": "cd modules/yoma && python3 scripts/validate_literal.py",
    "status:literal:yoma": "cd modules/yoma && python3 scripts/fetch_literal_en.py --status",
    "build": "node scripts/build.mjs",
    "postbuild": "node scripts/patch-dist-version.mjs",
    "preview": "npm run build && python3 -m http.server 4173 --bind 127.0.0.1 --directory dist",
    "check:deploy-html": "node scripts/check-deploy-html.mjs",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "0.25.5"
  }
}
